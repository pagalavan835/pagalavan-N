import javax.swing.*;
import java.awt.*;
import java.util.Random;

public class ColorChangingPanels {
    public static void main(String[] args) {
        // Create the main frame
        JFrame frame = new JFrame("BorderLayout Example");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(500, 500);
        frame.setLayout(new BorderLayout());

        // Create panels for each region
        JPanel northPanel = new JPanel();
        JPanel southPanel = new JPanel();
        JPanel eastPanel = new JPanel();
        JPanel westPanel = new JPanel();
        JPanel centerPanel = new JPanel();

        // Add panels to the frame
        frame.add(northPanel, BorderLayout.NORTH);
        frame.add(southPanel, BorderLayout.SOUTH);
        frame.add(eastPanel, BorderLayout.EAST);
        frame.add(westPanel, BorderLayout.WEST);
        frame.add(centerPanel, BorderLayout.CENTER);

        // Set initial background colors
        northPanel.setBackground(Color.RED);
        southPanel.setBackground(Color.BLUE);
        eastPanel.setBackground(Color.GREEN);
        westPanel.setBackground(Color.YELLOW);
        centerPanel.setBackground(Color.ORANGE);

        // Create a timer to change colors every 3 seconds
        Timer timer = new Timer(3000, e -> {
            Random random = new Random();
            northPanel.setBackground(new Color(random.nextInt(256), random.nextInt(256), random.nextInt(256)));
            southPanel.setBackground(new Color(random.nextInt(256), random.nextInt(256), random.nextInt(256)));
            eastPanel.setBackground(new Color(random.nextInt(256), random.nextInt(256), random.nextInt(256)));
            westPanel.setBackground(new Color(random.nextInt(256), random.nextInt(256), random.nextInt(256)));
            centerPanel.setBackground(new Color(random.nextInt(256), random.nextInt(256), random.nextInt(256)));
        });

        // Start the timer
        timer.start();

        // Make the frame visible
        frame.setVisible(true);
    }
}
