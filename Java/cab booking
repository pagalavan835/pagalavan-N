import java.util.*;
class CabBooking{
   int cabNumber;
   String cabName;
   int driverNumber;
   String dateofbooking;
   int Intime;
   int Outtime;
   double billamount;
   CabBooking(int n1,String n2,int n3,String n4,int n5,int n6)
   {
      cabNumber = n1;
      cabName = n2;
      driverNumber = n3;
      dateofbooking = n4;
      Intime = n5;
      Outtime = n6;
   }
   void display()
   {
      System.out.println("\nCab Number:"+cabNumber +"\nCab name:"+cabName +"\nDriver Number:"+driverNumber +"\nDate of Booking:"+dateofbooking +"\nIntime:"+Intime +
            "\nOuttime:"+Outtime);
   }
   CabBooking()
   {
      cabNumber=11111;
      cabName="ABCD";
      driverNumber=1234567890;
      dateofbooking="";
      Intime=0;
      Outtime=0;
   }
   void calculateBill()
   {
      int charge=100;
      billamount=(Outtime-Intime)*charge;
      System.out.println("Bill amount:"+"$"+billamount);
   }
}
public class ex1{
   public static void main(String[] args)
   {
      CabBooking[] cabs=new CabBooking[2];
      for(int i=0;i<2;i++)
      {
         Scanner in= new Scanner(System.in);
         System.out.print("Enter the Cab Number:");
         int n1=in.nextInt();
         System.out.print("Enter the Cab Name:");
         String n2=in.next();
         System.out.print("Enter the Driver Number:");
         int n3=in.nextInt();
         System.out.print("Enter the Date of Booking:");
         String n4=in.next();
         System.out.print("Enter the IN TIME:");
         int n5=in.nextInt();
         System.out.print("Enter the OUT TIME:");
         int n6=in.nextInt();
         cabs[i]=new CabBooking(n1,n2,n3,n4,n5,n6);
         cabs[i].calculateBill();
      }
      for(CabBooking c:cabs)
      {
         c.display();
         c.calculateBill();
      }
   }
}
