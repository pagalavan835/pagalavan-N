import java.util.*;
class Payment{
        String name;
        double amt;
        String date;
         static int id=0;
        Payment(String pname,double amount,String date){
                name=pname;
                amt=amount;
                this.date=date;
                id++;
        }
        void display() {
                System.out.println("BILL BILL");
                System.out.println("BILL ID:"+id);
                System.out.println("NAME:"+name);
                System.out.println("AMOUNT:"+amt);
                System.out.println("DATE:"+date);
        }
}

class Cash extends Payment{
        Cash(String pname,double amount,String date){

                super(pname,amount,date);
        }

        void computeBill() {
                amt+=(amt*0.12);
                super.display();
        }


}
class Card extends Payment{
        long card;
        int p;
        Card(String pname,double amount,String date,long cardno,int pin){
                super(pname,amount,date);

                card=cardno;
                p=pin;

        }
        void displayCard() {
                System.out.println("CARD DETAILS");
                System.out.println("CARD NUMBER:"+card);
                super.display();
        }
}
class Debit extends Card{
        Debit(String pname,double amount,String date,long cardno,int pin){
                super(pname,amount,date,cardno,pin);
        }
        void computeBill() {
                amt+=(amt*0.10);
                super.displayCard();
        }


}
class Credit extends Card{
        Credit(String pname,double amount,String date,long cardno,int pin){
                super(pname,amount,date,cardno,pin);
        }
        void computeBill() {
                amt+=(amt*0.05);
                super.displayCard();
        }


}

